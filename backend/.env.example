PORT=3001
JWT_SECRET=change-this-to-a-random-secret-string-at-least-32-chars
NODE_ENV=development
DB_PATH=./grocery.db
CORS_ORIGIN=http://localhost:3001
SEED_DEMO_DATA=false

# Kroger Developer API credentials. Keep real values in backend/.env only.
KROGER_CLIENT_ID=your-kroger-client-id
KROGER_CLIENT_SECRET=your-kroger-client-secret

# Optional. If omitted, the app uses USDA's low-volume public DEMO_KEY.
# USDA_FDC_API_KEY=your-usda-fooddata-central-key

# Production persistence target. Current demo still uses SQLite until the
# repository layer is switched to Postgres/Supabase.
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
# SUPABASE_STORAGE_BUCKET=receipts
